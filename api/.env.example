# ═══════════════════════════════════════
#  Общие
# ═══════════════════════════════════════
SECRET_KEY=change-me-to-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
DATABASE_URL=sqlite:////opt/dragons/api/dragons.db
APP_ENV=dev
DEV_LOGIN_ENABLED=true
FRONTEND_URL=https://belovolovhome.ru/dragons

# ═══════════════════════════════════════
#  VK OAuth — вход администратора
#  Получить: vk.ru/editapp → Ваше VK ID приложение
# ═══════════════════════════════════════
VK_CLIENT_ID=your_vk_client_id
VK_CLIENT_SECRET=your_vk_client_secret
VK_REDIRECT_URI=https://belovolovhome.ru/dragons/api/auth/vk-callback
VK_ALLOWED_IDS=123456789,987654321

# ═══════════════════════════════════════
#  VK Mini App — коллекция в WebView
#  Получить: vk.ru/editapp → Защищённый ключ
# ═══════════════════════════════════════
VK_APP_ID=your_mini_app_id
VK_APP_SECRET=your_protected_client_secret

# ═══════════════════════════════════════
#  VK Bot — LongPoll бот
#  Получить: Настройки сообщества → API
# ═══════════════════════════════════════
VK_GROUP_TOKEN=your_vk_group_token
VK_GROUP_ID=your_vk_group_id
ADMIN_VK_ID=your_admin_vk_id
ANTI_CHEAT_MULTIPLIER=5
